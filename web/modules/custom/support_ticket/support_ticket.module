<?php

/**
 * @file
 * Primary module hooks for the Support Ticket module.
 */

use Drupal\comment\CommentInterface;
use Drupal\Core\Access\AccessResult;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Entity\EntityStorageException;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Drupal\support_ticket\TicketStatusService;
use Drupal\user\UserInterface;
use Drupal\views\Plugin\views\query\Sql as ViewsSqlQuery;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_modules_installed().
 */
function support_ticket_modules_installed(array $modules, bool $is_sync): void {
  if (!in_array('support_ticket', $modules, TRUE)) {
    return;
  }
  \Drupal::moduleHandler()->loadInclude('support_ticket', 'install');
  support_ticket_set_front_page();
  support_ticket_ensure_ticket_comments();
  support_ticket_ensure_comment_subject_hidden();
}

/**
 * Implements hook_preprocess_HOOK() for comment templates.
 */
function support_ticket_preprocess_comment(array &$variables): void {
  unset($variables['title']);
}

/**
 * Implements hook_entity_base_field_info_alter().
 */
function support_ticket_entity_base_field_info_alter(array &$fields, EntityTypeInterface $entity_type): void {
  if ($entity_type->id() === 'node' && isset($fields['title'])) {
    $fields['title']->addConstraint('TicketTitleLength', ['max' => 100]);
  }
}

/**
 * Implements hook_entity_bundle_field_info_alter().
 */
function support_ticket_entity_bundle_field_info_alter(array &$fields, EntityTypeInterface $entity_type, string $bundle): void {
  if ($entity_type->id() === 'node' && $bundle === 'ticket') {
    $fields['field_description']->addConstraint('TicketDescriptionLength', ['max' => 1000]);
    $fields['field_assigned_to']->addConstraint('TicketAssigneeIsAgent');
  }
  if ($entity_type->id() === 'comment' && $bundle === 'comment') {
    $fields['comment_body']->addConstraint('CommentMessageLength', ['max' => 1000]);
  }
}

/**
 * Implements hook_entity_type_alter().
 */
function support_ticket_entity_type_alter(array &$entity_types): void {
  $entity_types['node']->addConstraint('TicketNotTerminal', ['bundles' => ['ticket']]);
  $entity_types['node']->addConstraint('TicketStatusTransition', ['bundles' => ['ticket']]);
  if (isset($entity_types['comment'])) {
    $entity_types['comment']->addConstraint('TicketNotTerminal');
  }
}

/**
 * Implements hook_node_access().
 */
function support_ticket_node_access(NodeInterface $node, string $op, AccountInterface $account): AccessResult {
  if ($node->bundle() !== 'ticket') {
    return AccessResult::neutral();
  }

  $access = \Drupal::service('support_ticket.access');
  $result = match ($op) {
    'view' => $access->canView($account, $node)
      ? AccessResult::allowed()
      : AccessResult::forbidden(),
    'update' => $access->canUpdate($account, $node)
      ? AccessResult::allowed()
      : AccessResult::forbidden(),
    'delete' => $access->canDelete($account, $node)
      ? AccessResult::allowed()
      : AccessResult::forbidden(),
    default => AccessResult::neutral(),
  };

  return $result
    ->addCacheableDependency($node)
    ->cachePerPermissions()
    ->cachePerUser();
}

/**
 * Implements hook_entity_access().
 */
function support_ticket_entity_access(EntityInterface $entity, string $op, AccountInterface $account): AccessResult {
  if ($entity instanceof CommentInterface) {
    $ticket = $entity->getCommentedEntity();
    if (!$ticket instanceof NodeInterface || $ticket->bundle() !== 'ticket') {
      return AccessResult::neutral();
    }

    $access = \Drupal::service('support_ticket.access');
    $result = match ($op) {
      'view' => $access->canView($account, $ticket)
        ? AccessResult::allowed()
        : AccessResult::forbidden(),
      'create' => $access->canAddComment($account, $ticket)
        ? AccessResult::allowed()
        : AccessResult::forbidden(),
      'update' => $access->canEditComment($account, $entity)
        ? AccessResult::allowed()
        : AccessResult::forbidden(),
      'delete' => AccessResult::forbidden(),
      default => AccessResult::neutral(),
    };

    return $result
      ->addCacheableDependency($entity)
      ->addCacheableDependency($ticket)
      ->cachePerPermissions()
      ->cachePerUser();
  }

  return AccessResult::neutral();
}

/**
 * Implements hook_entity_presave().
 */
function support_ticket_entity_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'ticket' || !$entity->isNew()) {
    return;
  }

  if ($entity->get('field_ticket_status')->isEmpty()) {
    $entity->set('field_ticket_status', TicketStatusService::STATUS_OPEN);
  }
  if ($entity->get('field_priority')->isEmpty()) {
    $entity->set('field_priority', 'medium');
  }
  $entity->setPublished(TRUE);
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node_form.
 */
function support_ticket_form_node_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  /** @var \Drupal\node\NodeForm $form_object */
  $form_object = $form_state->getFormObject();
  $node = $form_object->getEntity();
  if (!$node instanceof NodeInterface || $node->bundle() !== 'ticket') {
    return;
  }

  $account = \Drupal::currentUser();
  $access = \Drupal::service('support_ticket.access');

  if (isset($form['field_ticket_status'])) {
    $form['field_ticket_status']['#access'] = FALSE;
  }

  if (isset($form['field_assigned_to']) && !$access->canAssign($account, $node)) {
    $form['field_assigned_to']['#access'] = FALSE;
  }

  $form['#validate'][] = 'support_ticket_node_ticket_form_validate';
}

/**
 * Validates ticket node forms for assignment tampering and status changes.
 */
function support_ticket_node_ticket_form_validate(array &$form, FormStateInterface $form_state): void {
  /** @var \Drupal\node\NodeForm $form_object */
  $form_object = $form_state->getFormObject();
  $node = $form_object->getEntity();
  if (!$node instanceof NodeInterface || $node->bundle() !== 'ticket') {
    return;
  }

  $account = \Drupal::currentUser();
  $access = \Drupal::service('support_ticket.access');

  if (!$access->canAssign($account, $node) && isset($form['field_assigned_to'])) {
    $submitted = $form_state->getValue('field_assigned_to');
    $submitted_target = is_array($submitted) ? ($submitted[0]['target_id'] ?? NULL) : NULL;
    $original_target = NULL;
    if (!$node->isNew() && $node->original instanceof NodeInterface) {
      $original_target = $node->original->get('field_assigned_to')->target_id;
    }
    if ($submitted_target && (int) $submitted_target !== (int) $original_target) {
      $form_state->setErrorByName('field_assigned_to', t('You are not allowed to assign tickets.'));
    }
  }

  if (!$node->isNew() && $node->original instanceof NodeInterface) {
    $original_status = $node->original->get('field_ticket_status')->value;
    $submitted = $form_state->getValue('field_ticket_status');
    $submitted_status = is_array($submitted) ? ($submitted[0]['value'] ?? $original_status) : $original_status;
    if ($submitted_status !== $original_status) {
      $form_state->setError($form, t('Status can only be changed via the transition form.'));
    }
  }
}

/**
 * Implements hook_entity_view_alter().
 */
function support_ticket_entity_view_alter(array &$build, EntityInterface $entity, $display): void {
  if (!$entity instanceof NodeInterface || $entity->bundle() !== 'ticket') {
    return;
  }

  \Drupal::service('support_ticket.access')
    ->filterRenderedTicket($build, \Drupal::currentUser());
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for user_login_form.
 */
function support_ticket_form_user_login_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form['#submit'][] = 'support_ticket_user_login_form_submit';
}

/**
 * Sets default post-login redirect to the ticket list when no destination is set.
 */
function support_ticket_user_login_form_submit(array &$form, FormStateInterface $form_state): void {
  $request = \Drupal::request();
  if (!$request->query->has('destination') && !$request->request->has('destination')) {
    $form_state->setRedirect('view.tickets.page_1');
  }
}

/**
 * Implements hook_menu_local_tasks_alter().
 */
function support_ticket_menu_local_tasks_alter(array &$data, string $route_name): void {
  if (!in_array($route_name, ['entity.node.canonical', 'entity.node.edit_form'], TRUE)) {
    return;
  }

  $node = \Drupal::routeMatch()->getParameter('node');
  if (!$node instanceof NodeInterface || $node->bundle() !== 'ticket') {
    return;
  }

  $account = \Drupal::currentUser();
  $access = \Drupal::service('support_ticket.access');
  $status = \Drupal::service('support_ticket.status');

  foreach ($data['tabs'] as &$tab_level) {
    if (!$access->canUpdate($account, $node)) {
      unset($tab_level['entity.node.edit_form']);
      unset($tab_level['support_ticket.ticket_transition']);
      continue;
    }
    if (!$status->canUserTransitionTicket($account, $node)) {
      unset($tab_level['support_ticket.ticket_transition']);
    }
  }
}

/**
 * Implements hook_views_query_alter().
 */
function support_ticket_views_query_alter(ViewExecutable $view, ViewsSqlQuery $query): void {
  if ($view->id() !== 'tickets') {
    return;
  }

  \Drupal::service('support_ticket.access')
    ->applyListScopeToViewsQuery($query, \Drupal::currentUser());
}

/**
 * Implements hook_views_pre_render().
 */
function support_ticket_views_pre_render(ViewExecutable $view): void {
  if ($view->id() !== 'tickets') {
    return;
  }

  $account = \Drupal::currentUser();
  if ($account->hasRole('reporter') && isset($view->field['field_assigned_to'])) {
    unset($view->field['field_assigned_to']);
  }
}

/**
 * Implements hook_user_predelete().
 */
function support_ticket_user_predelete(UserInterface $account): void {
  $access = \Drupal::service('support_ticket.access');
  $actor = \Drupal::currentUser();
  if (!$access->userDeletionAllowed($account, $actor)) {
    if ($actor->id() === $account->id()) {
      throw new EntityStorageException('Administrators cannot delete their own account.');
    }
    throw new EntityStorageException('User cannot be deleted while assigned to one or more tickets.');
  }
}
